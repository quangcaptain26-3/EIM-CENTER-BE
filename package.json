{
  "name": "eim-center-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "db:init": "psql -U postgres -f database/scripts/01_create_db.sql",
    "db:reset": "node -r dotenv/config -e \"(()=>{const{spawnSync}=require('child_process');const{join}=require('path');const u=process.env.DATABASE_URL;if(!u){console.error('[EIM] DATABASE_URL missing');process.exit(1)}const r=spawnSync('psql',[u,'-f',join('database','scripts','00_full_reset.sql')],{stdio:'inherit',shell:process.platform==='win32'});process.exit(r.status===null?1:r.status)})()\"",
    "db:migrate": "node -r dotenv/config -e \"(()=>{const{spawnSync}=require('child_process');const{join}=require('path');const u=process.env.DATABASE_URL;if(!u){console.error('[EIM] DATABASE_URL missing');process.exit(1)}const r=spawnSync('psql',[u,'-f',join('database','scripts','01_run_migrations.sql')],{stdio:'inherit',shell:process.platform==='win32'});process.exit(r.status===null?1:r.status)})()\"",
    "db:seed": "node -r dotenv/config -e \"(()=>{const{spawnSync}=require('child_process');const{join}=require('path');const u=process.env.DATABASE_URL;if(!u){console.error('[EIM] DATABASE_URL missing');process.exit(1)}const r=spawnSync('psql',[u,'-f',join('database','scripts','02_run_seeds.sql')],{stdio:'inherit',shell:process.platform==='win32'});process.exit(r.status===null?1:r.status)})()\"",
    "db:smoke": "node -r dotenv/config -e \"(()=>{const{spawnSync}=require('child_process');const{join}=require('path');const u=process.env.DATABASE_URL;if(!u){console.error('[EIM] DATABASE_URL missing');process.exit(1)}const r=spawnSync('psql',[u,'-f',join('database','scripts','03_smoke_test.sql')],{stdio:'inherit',shell:process.platform==='win32'});process.exit(r.status===null?1:r.status)})()\"",
    "db:install": "node -r dotenv/config -e \"(()=>{const{spawnSync}=require('child_process');const{join}=require('path');const u=process.env.DATABASE_URL;if(!u){console.error('[EIM] DATABASE_URL missing');process.exit(1)}const r=spawnSync('psql',[u,'-f',join('database','scripts','INSTALL.sql')],{stdio:'inherit',shell:process.platform==='win32'});process.exit(r.status===null?1:r.status)})()\"",
    "db:fresh": "npm run db:install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.3",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
